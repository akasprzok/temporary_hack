<h2><%= @title %></h2>

<%= f = form_for @changeset, "#",
  id: "clicker-form",
  phx_target: @myself,
  phx_change: "validate",
  phx_submit: "save" %>

  <%= label f, :clicks %>
  <%= number_input f, :clicks %>
  <%= error_tag f, :clicks %>

  <%= submit "Save", phx_disable_with: "Saving..." %>
</form>
